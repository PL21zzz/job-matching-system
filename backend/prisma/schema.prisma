generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. Quản lý Quyền
model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique // Admin, Employer, Candidate
  users User[]

  @@map("roles")
}

// 2. Người dùng (Hỗ trợ cả Local và Google Login)
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String?  @map("password_hash") // Nullable cho Google Login

  provider      String   @default("local")     // "local" hoặc "google"
  providerId    String?  @map("provider_id")    // ID từ Google

  fullName      String   @map("full_name")
  status        String   @default("PENDING")    // PENDING, ACTIVE, BANNED
  createdAt     DateTime @default(now()) @map("created_at")

  roleId        Int?     @map("role_id")
  role          Role?    @relation(fields: [roleId], references: [id])
  refreshTokenHash String?

  // Quan hệ 1-1 với các loại Profile
  candidateProfile CandidateProfile?
  employerProfile  EmployerProfile?

  @@map("users")
}

// 3. Mã xác thực OTP
model Otp {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("otps")
}

// 4. Hồ sơ Ứng viên (Dành cho người khuyết tật)
model CandidateProfile {
  id                 String          @id @default(uuid())
  userId             String          @unique @map("user_id")
  user               User            @relation(fields: [userId], references: [id])
  fullName           String?         @map("full_name")
  dob                DateTime?
  phone              String?
  address            String?
  disabilityTypeId   Int?            @map("disability_type_id")
  disabilityType     DisabilityType? @relation(fields: [disabilityTypeId], references: [id])

  @@map("candidate_profiles")
}

// 5. Hồ sơ Nhà tuyển dụng
model EmployerProfile {
  id                    String  @id @default(uuid())
  userId                String  @unique @map("user_id")
  user                  User    @relation(fields: [userId], references: [id])
  companyName           String? @map("company_name")
  taxCode               String? @map("tax_code")
  description           String?
  address               String?
  accessibilityFeatures String? @map("accessibility_features")

  @@map("employer_profiles")
}

// 6. Danh mục loại khuyết tật
model DisabilityType {
  id               Int                @id @default(autoincrement())
  name             String             @unique
  description      String?
  candidateProfiles CandidateProfile[]

  @@map("disability_types")
}
