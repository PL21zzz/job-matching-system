// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Khai báo bảng Role
model Role {
  id    Int     @id @default(autoincrement())
  name  String  @unique // Admin, Employer, Candidate
  users User[]  // Quan hệ 1-N: 1 Role có nhiều User
}

// Khai báo bảng User
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  fullName      String   @map("full_name")
  createdAt     DateTime @default(now()) @map("created_at")

  // Chỉ giữ lại MỘT dòng status này thôi:
  status        String   @default("PENDING") // PENDING (chờ xác thực), ACTIVE (đã xác thực), BANNED

  // Thiết lập khóa ngoại (Foreign Key) nối với bảng Role
  roleId        Int?     @map("role_id")
  role          Role?    @relation(fields: [roleId], references: [id])

  @@map("users")
}

model Otp {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String   // Lưu mã OTP (đã băm hoặc để thô tùy bạn, ở đây để thô cho dễ test)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
