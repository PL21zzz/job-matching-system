  usecase "Manage Employer Profile" as UC12
  usecase "Create Inclusive Job Post" as UC13
  usecase "Configure Structured\nAccommodations" as UC14
  usecase "Review Applications" as UC15
  usecase "Update Application Status" as UC16

  usecase "View Dashboard Statistics" as UC17
  usecase "Manage Users" as UC18
  usecase "Review Jobs and Applications" as UC19

